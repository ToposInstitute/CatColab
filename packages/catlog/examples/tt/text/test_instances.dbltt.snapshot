set_theory ThSchema
#/ result: set theory to ThSchema

type WeightedGraph := [
  V : Entity,
  E : Entity,
  Weight : AttrType,
  src : (Hom Entity)[E, V],
  tgt : (Hom Entity)[E, V],
  weight : Attr[E, Weight]
]
#/ declared: WeightedGraph

diagram Edge : @Instance(WeightedGraph) := [
    e : @over .E,
]
#/ declared: Edge
#/ instance generators:
#/   e : E

diagram I : @Instance(WeightedGraph) := [
    v1 : @over .V,
    v2 : @over .V,
    w : @over .Weight,
    we : Edge, 
    wf : Edge,
    _ : (we.src(e) == v1),
    _ : (we.tgt(e) == v2),
    _ : (wf.src(e) == v2),
    _ : (wf.tgt(e) == v1),
    _ : (we.weight(e) == w),
    _ : (wf.weight(e) == w)
]
#/ declared: I
#/ instance generators:
#/   v1 : V
#/   v2 : V
#/   w : Weight
#/   we.e : E
#/   wf.e : E
#/ instance equations:
#/   src(we.e) == v1
#/   tgt(we.e) == v2
#/   src(wf.e) == v2
#/   tgt(wf.e) == v1
#/   weight(we.e) == w
#/   weight(wf.e) == w

diagram I3 : @Instance(WeightedGraph) := [
    e1 : @over .E,
    e2 : @over .E
]
#/ declared: I3
#/ instance generators:
#/   e1 : E
#/   e2 : E

