set_theory ThSignedCategory

model PredPrey := [
  Pred : Object,
  Prey : Object,
  eats : Negative[Pred, Prey],
  feeds : (Hom Object)[Prey, Pred]
]

model TwoLevelFoodChain := [
  Grass : Object,
  Rabbit : Object,
  Fox : Object,
  level1 : PredPrey & [ .Prey := Grass, .Pred := Rabbit ],
  level2 : PredPrey & [ .Prey := Rabbit, .Pred := Fox ]
]

uwd TwoLevelFoodChain

model TwoPredSystem := [
  main: PredPrey,
  secondary: PredPrey & [ .Prey := main.Prey ]
]

uwd TwoPredSystem
