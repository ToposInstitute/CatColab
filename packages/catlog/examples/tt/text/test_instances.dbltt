set_theory ThSchema

type WeightedGraph := [
  V : Entity,
  E : Entity,
  Weight : AttrType,
  src : (Hom Entity)[E, V],
  tgt : (Hom Entity)[E, V],
  weight : Attr[E, Weight]
]

def Edge : WeightedGraph := [
    E := [e]
]

def I : WeightedGraph := [
    V := [v1, v2],
    Weight := [w],
    we : Edge,
    wf : Edge,
    we.src(e) := v1,
    we.tgt(e) := v2,
    wf.src(e) := v2,
    wf.tgt(e) := v1,
    we.weight(e) := w,
    wf.weight(e) := w
]

def I3 : WeightedGraph := [
    E := [e1, e2]
]