set_theory ThSchema

type WeightedGraph := [
  V : Entity,
  E : Entity,
  Weight : AttrType,
  src : (Hom Entity)[E, V],
  tgt : (Hom Entity)[E, V],
  weight : Attr[E, Weight]
]

def Edge : WeightedGraph := [
    e : @over .E,
]

#/ Needs some sugar, maybe analogous to in the notebook
def I : WeightedGraph := [
    v1 : @over .V,
    v2 : @over .V,
    w : @over .Weight,
    we : Edge,
    wf : Edge,
    _ : (we.src(e) == v1),
    _ : (we.tgt(e) == v2),
    _ : (wf.src(e) == v2),
    _ : (wf.tgt(e) == v1),
    _ : (we.weight(e) == w),
    _ : (wf.weight(e) == w)
]

def I3 : WeightedGraph := [
    e1 : @over .E,
    e2 : @over .E
]