set_theory ThSchema

model WeightedGraph := [
  V : Entity,
  E : Entity,
  Weight : AttrType,
  src : (Hom Entity)[E, V],
  tgt : (Hom Entity)[E, V],
  weight : Attr[E, Weight]
]

generate WeightedGraph

model EntityArr := [
  dom : Entity,
  cod : Entity,
  arr : (Hom Entity)[dom, cod]
]

model Graph1 := [
  V : Entity,
  E : Entity,
  src : EntityArr & [ .dom := E, .cod := V ],
  tgt : EntityArr & [ .dom := E, .cod := V ],
]

chk [G : Graph1] (G.src.arr : (Hom Entity)[G.E, G.V])

chk [G : Graph1] (G.src : EntityArr)

chk [G : Graph1] (G.src : EntityArr & [ .dom := G.E ] )

#(should_fail)
chk [G : Graph1] (G.src : EntityArr & [ .dom := G.V ] )

norm [x : [a : Entity, b : @sing a]] x.b

#(should_fail)
model Graph1 := [
  V : Entity,
  E : Entity,
  src : EntityArr & [ .dom := E, .dom := V ]
]

model Graph := [
  V : Entity,
  E : Entity,
  src : (Hom Entity)[E, V],
  tgt : (Hom Entity)[E, V]
]

def reverse[G : Graph] : Graph := [
  V := G.V,
  E := G.E,
  src := G.tgt,
  tgt := G.src
]

#(should_fail)
def reverse1[G : Graph] : Graph := [
  V := G.E,
  E := G.E,
  src := G.tgt,
  tgt := G.src
]

norm [G : Graph] (reverse[G]).E
syn [G : Graph] (reverse[G]).src

model ReflexiveGraph := [
  V : Entity,
  E : Entity,
  src : (Hom Entity)[E, V],
  tgt : (Hom Entity)[E, V],
  refl : (Hom Entity)[V, E]
]

def edge_id[G : ReflexiveGraph] : (Hom Entity)[G.E, G.E] := @id G.E

def edge_src[G : ReflexiveGraph] : (Hom Entity)[G.E, G.E] := G.src * G.refl

model Graph2 := [
  V : Entity,
  g1 : Graph & [ .V := V],
  g2 : Graph & [ .V := V]
]

syn [g : Graph2] g.g1.V

norm [g : Graph2] g.g1.V

generate Graph2

model ProfunctorGraph := [
  g1 : Graph,
  g2 : Graph,
  het : (Hom Entity)[g1.V, g2.V]
]

generate ProfunctorGraph

model WeightedGraph2 := [
  V : Entity,
  g1 : WeightedGraph & [ .V := V ],
  g2 : WeightedGraph & [ .V := V ]
]

generate WeightedGraph2

set_theory ThCategory

#(should_fail)
model Set := [
  A : Entity,
]

model Set := [
  A : Object
]

model DDS := [
  X : Object,
  φ : (Hom Object)[X, X]
]

set_theory ThSignedCategory

model NegFeedback := [
  X : Object,
  Y : Object,
  f : (Hom Object)[X, Y],
  g : Negative[Y, X]
]

generate NegFeedback

#(should_fail)
model NegFeedback1 := [
  X : Object,
  Y : Object,
  f : (Hom Object)[@hole, Y],
  g : Negative[Y, f]
]

generate NegFeedback1
