set_theory ThMulticategory

model SigMonoid := [
  M : Object,
  op : Multihom[[M, M], M],
  unit : Multihom[[], M]
]

generate SigMonoid

model SigRig := [
  R : Object,
  Add : SigMonoid & [ .M := R ],
  Mul : SigMonoid & [ .M := R ]
]

generate SigRig

set_theory ThSymMonoidalCategory

model SIR := [
  S : Object,
  I : Object,
  R : Object,
  infect : (Hom Object)[@tensor [S, I], @tensor [I, I]],
  recover : (Hom Object)[I, R]
]

generate SIR

syn [P: SIR] (@tensor [P.S, P.I])

model SIRV := [
  Unvax : SIR,
  V : Object,
  vaccinate : (Hom Object)[Unvax.S, V]
]

generate SIRV

#(should_fail)
model BadOpApp := [
   X : Object,
   f : (Hom Object)[@tensor X, X],
]
