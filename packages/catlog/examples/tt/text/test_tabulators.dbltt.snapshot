#/ tried to convert between types of different type constructors
#/ --> examples/tt/text/test_tabulators.dbltt:32:16
#/ 32|     l : Link[z,@tab f]
#/ 32|                ^^^^^^

type SI := [
    S : Object,
    I : Object,
    inf : WalkingLink & [.x := S, .y := I, .z := I]
]
#/ declared: SI

generate SI
#/ result: model generated by 2 objects and 1 morphism
#/ S : Object
#/ I : Object
#/ inf.f : S -> I : Hom Object

