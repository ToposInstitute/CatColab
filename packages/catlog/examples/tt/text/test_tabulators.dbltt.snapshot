type WalkingLink := [
    x : Object,
    y : Object, 
    z : Object,
    f : (Hom Object)[x,y],
    l : Link[z,@tab f]
]
#/ declared: WalkingLink
#/ unexpected errors:
#/ error[elab]: unexpected notation for term
#/ --> examples/tt/text/test_tabulators.dbltt:32:16
