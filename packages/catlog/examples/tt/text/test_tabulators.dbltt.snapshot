set_theory ThCategoryLinks
#/ result: set theory to ThCategoryLinks

type SIR := [
    S : Object,
    I : Object,
    R : Object, 
    inf : (Hom Object)[S,I],
    rec : (Hom Object)[I,R],
    _ : Link[I,@tab inf]
]
#/ declared: SIR

generate SIR
#/ result: model generated by 3 objects and 3 morphisms
#/ S : Object
#/ I : Object
#/ R : Object
#/ inf : S -> I : Hom Object
#/ rec : I -> R : Hom Object
#/ _ : I -> inf : Link

type Endo := [
    A : Object,
    f : (Hom Object)[A,A],
]
#/ declared: Endo

generate Endo
#/ result: model generated by 1 object and 1 morphism
#/ A : Object
#/ f : A -> A : Hom Object

#(should_fail)
type LinkFlows := [
    E : Endo,
    l : Link[@tab E.f,@tab E.f]
]
#/ declared: LinkFlows
#/ expected errors:
#/ error[elab]: synthesized type Tab Hom Object does not match expected type Object:
#/ object types Tab Hom Object and Object are not equal
#/ --> examples/tt/text/test_tabulators.dbltt:24:14
#/ 24|     l : Link[@tab E.f,@tab E.f]
#/ 24|              ^^^^^^^^

type WalkingLink := [
    x : Object,
    y : Object, 
    z : Object,
    f : (Hom Object)[x,y],
    l : Link[z,@tab f]
]
#/ declared: WalkingLink

type SI := [
    S : Object,
    I : Object,
    inf : WalkingLink & [.x := S, .y := I, .z := I]
]
#/ declared: SI

generate SI
#/ result: model generated by 2 objects and 2 morphisms
#/ S : Object
#/ I : Object
#/ inf.f : S -> I : Hom Object
#/ inf.l : I -> inf.f : Link

chk [sf : SI] (sf.inf.l : Link[sf.I,@tab sf.inf.f])
#/ result: sf.inf.l

chk [sf : SI] (sf.inf : WalkingLink)
#/ result: sf.inf

chk [sf : SI] (sf.inf : WalkingLink & [ .x := sf.S])
#/ result: sf.inf

#(should_fail)
chk [sf : SI] (sf.inf : WalkingLink & [.x := sf.I])
#/ result: ?0
#/ expected errors:
#/ error[elab]: evaluated term [x := sf.S, y := sf.I, z := sf.I, f := sf.inf.f, l := sf.inf.l] is not an element of specialized type [x : Object,
#/   y : Object,
#/   z : Object,
#/   f : (Hom Object)[self.x, self.y],
#/   l : (Link)[self.z, (@tab self.f)]]
#/ &
#/   [.x : @sing sf.I]:
#/ Neutrals sf.S and sf.I are not equal.
#/ --> examples/tt/text/test_tabulators.dbltt:50:16
#/ 50| chk [sf : SI] (sf.inf : WalkingLink & [.x := sf.I])
#/ 50|                ^^^^^^

def act_on_link[d : SI] : Link[d.S,@tab d.inf.f] := d.inf.f * d.inf.l
#/ declared: act_on_link

type Triangle := [
    x : Object,
    y : Object,
    z : Object,
    f : (Hom Object)[x,y],
    g : (Hom Object)[y,z],
    l : Link[z, @tab (f * g)]
]
#/ declared: Triangle

def delete_y[T : Triangle] : SI := [
    S := T.x,
    I := T.z,
    inf := [
        x := T.x,
        y := T.z,
        z := T.z,
        f := T.f * T.g,
        l := T.l
    ]
]
#/ declared: delete_y

syn [T : Triangle] delete_y[T].inf.l
#/ result: delete_y[T].inf.l : (Link)[T.z, (@tab T.f · T.g)]

