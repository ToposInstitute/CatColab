type Triangle := [
    x : Object,
    y : Object,
    z : Object,
    f : (Hom Object)[x,y],
    g : (Hom Object)[y,z],
    l : Link[z, @tab (f * g)]
]
#/ declared: Triangle

def delete_y[T : Triangle] : SI := [
    S := T.x,
    I := T.z,
    inf := [
        x := T.x,
        y := T.z,
        z := T.z,
        f := T.f * T.g,
        l := T.l
    ]
]
#/ declared: delete_y
#/ unexpected errors:
#/ error[elab]: synthesized type (Link)[T.z, (@tab T.f · T.g)] does not match expected type (Link)[T.z, ?2]:
#/ could not convert codomains: failed to match terms (@tab T.f · T.g) and ?2
#/ --> examples/tt/text/test_tabulators.dbltt:71:14
#/ 71|         l := T.l
#/ 71|              ^^^

syn [T : Triangle] delete_y[T].inf.l
#/ result: delete_y[T].inf.l : (Link)[T.z, ?2]

