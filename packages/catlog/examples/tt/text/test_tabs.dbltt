set_theory ThCategoryLinks

type SIR := [
    S : Object,
    I : Object,
    R : Object, 
    si : (Hom Object)[S,I],
    ir : (Hom Object)[I,R],
    isi : Link[I,@tab si],
    rir : Link[R,@tab ir]
]

generate SIR

type WalkingLink := [
    x : Object,
    y : Object, 
    z : Object,
    f : (Hom Object)[x,y],
    l : Link[z,@tab f]
]

type SI := [
    S : Object,
    I : Object,
    si : (Hom Object)[S,I],
    isi : WalkingLink & [.x := S, .y := I, .z := I, .f := si]
]

generate SI