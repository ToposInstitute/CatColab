set_theory ThCategoryLinks
#/ result: set theory to ThCategoryLinks

type SIR := [
    S : Object,
    I : Object,
    R : Object, 
    si : (Hom Object)[S,I],
    ir : (Hom Object)[I,R],
    isi : Link[I,@tab si],
    rir : Link[R,@tab ir]
]
#/ declared: SIR

generate SIR
#/ result: model generated by 3 objects and 4 morphisms
#/ S : Object
#/ I : Object
#/ R : Object
#/ si : S -> I : Hom Object
#/ ir : I -> R : Hom Object
#/ isi : I -> si : Link
#/ rir : R -> ir : Link

type WalkingLink := [
    x : Object,
    y : Object, 
    z : Object,
    f : (Hom Object)[x,y],
    l : Link[z,@tab f]
]
#/ declared: WalkingLink

type SI := [
    S : Object,
    I : Object,
    si : (Hom Object)[S,I],
    isi : WalkingLink & [.x := S, .y := I, .z := I, .f := si]
]
#/ declared: SI

generate SI
#/ result: model generated by 2 objects and 2 morphisms
#/ S : Object
#/ I : Object
#/ si : S -> I : Hom Object
#/ isi.l : I -> si : Link

