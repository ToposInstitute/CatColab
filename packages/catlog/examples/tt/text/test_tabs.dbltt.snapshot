set_theory ThCategoryLinks
#/ result: set theory to ThCategoryLinks

type SIR := [
    S : Object,
    I : Object,
    R : Object, 
    si : (Hom Object)[S,I],
    ir : (Hom Object)[I,R],
    isi : Link[I,@tab si],
    rir : Link[R,@tab ir]
]
#/ declared: SIR

generate SIR
#/ result: model generated by 3 objects and 4 morphisms
#/ S : Object
#/ I : Object
#/ R : Object
#/ si : S -> I : Hom Object
#/ ir : I -> R : Hom Object
#/ isi : I -> si : Link
#/ rir : R -> ir : Link

type Endo := [
    A : Object,
    f : (Hom Object)[A,A],
]
#/ declared: Endo

generate Endo
#/ result: model generated by 1 object and 1 morphism
#/ A : Object
#/ f : A -> A : Hom Object

#(should_fail)
type LinkFlows := [
    E : Endo,
    l : Link[@tab E.f,@tab E.f]
]
#/ declared: LinkFlows
#/ expected errors:
#/ error[elab]: synthesized type Tab Hom Object does not match expected type Object:
#/ object types Tab Hom Object and Object are not equal
#/ --> examples/tt/text/test_tabs.dbltt:25:14
#/ 25|     l : Link[@tab E.f,@tab E.f]
#/ 25|              ^^^^^^^^

type WalkingLink := [
    x : Object,
    y : Object, 
    z : Object,
    f : (Hom Object)[x,y],
    l : Link[z,@tab f]
]
#/ declared: WalkingLink

type SI := [
    S : Object,
    I : Object,
    isi : WalkingLink & [.x := S, .y := I, .z := I]
]
#/ declared: SI

generate SI
#/ result: model generated by 2 objects and 2 morphisms
#/ S : Object
#/ I : Object
#/ isi.f : S -> I : Hom Object
#/ isi.l : I -> isi.f : Link

chk [sf : SI] (sf.isi.l : Link[sf.I,@tab sf.isi.f])
#/ result: sf.isi.l

chk [sf : SI] (sf.isi : WalkingLink)
#/ result: sf.isi

chk [sf : SI] (sf.isi : WalkingLink & [ .x := sf.S])
#/ result: sf.isi

#(should_fail)
chk [sf : SI] (sf.isi : WalkingLink & [.x := sf.I])
#/ result: ?0
#/ expected errors:
#/ error[elab]: evaluated term [x := sf.S, y := sf.I, z := sf.I, f := sf.isi.f, l := sf.isi.l] is not an element of specialized type [x : Object,
#/   y : Object,
#/   z : Object,
#/   f : (Hom Object)[self.x, self.y],
#/   l : (Link)[self.z, (@tab self.f)]]
#/ &
#/   [.x : @sing sf.I]:
#/ Neutrals sf.S and sf.I are not equal.
#/ --> examples/tt/text/test_tabs.dbltt:51:16
#/ 51| chk [sf : SI] (sf.isi : WalkingLink & [.x := sf.I])
#/ 51|                ^^^^^^

def act_on_link[d : SI] : Link[d.S,@tab d.isi.f] := d.isi.f * d.isi.l
#/ declared: act_on_link

type Triangle := [
    x : Object,
    y : Object,
    z : Object,
    f : (Hom Object)[x,y],
    g : (Hom Object)[y,z],
    l : Link[z, @tab (f * g)]
]
#/ declared: Triangle

def delete_y[T : Triangle] : SI := [
    S := T.x,
    I := T.z,
    isi := [
        x := T.x,
        y := T.z,
        z := T.z,
        f := T.f * T.g,
        l := T.l
    ]
]
#/ declared: delete_y

syn [T : Triangle] delete_y[T].isi.l
#/ result: delete_y[T].isi.l : (Link)[T.z, (@tab T.f · T.g)]

