{
    "name": "catcolab-ui-components",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./*": "./src/*"
    },
    "scripts": {
        "format": "oxfmt .",
        "lint": "oxlint --fix && oxfmt . &&  stylelint 'src/**/*.css' --fix",
        "check": "pnpm run lint && tsc",
        "ci": "tsc --noEmit && oxlint --deny-warnings && oxfmt --check . && stylelint 'src/**/*.css'",
        "dev": "storybook dev -p 6006 --no-version-updates --no-open",
        "build": "NODE_ENV=production storybook build",
        "test": "vitest --project=storybook"
    },
    "dependencies": {
        "@corvu/dialog": "^0.2.4",
        "@corvu/disclosure": "^0.2.2",
        "@corvu/popover": "^0.2.0",
        "@corvu/resizable": "^0.2.5",
        "@corvu/tooltip": "^0.2.2",
        "@github/relative-time-element": "^5.0.0",
        "@solid-primitives/active-element": "^2.1.3",
        "@solid-primitives/destructure": "^0.2.1",
        "katex": "^0.16.22",
        "lucide-solid": "^0.471.0",
        "shiki": "^4.0.2",
        "solid-js": "^1.9.12"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^4.1.3",
        "@storybook/addon-a11y": "^10.3.5",
        "@storybook/addon-docs": "^10.3.5",
        "@storybook/addon-links": "^10.3.5",
        "@storybook/addon-onboarding": "^10.3.5",
        "@storybook/addon-vitest": "^10.3.5",
        "@storybook/builder-vite": "^10.3.5",
        "@types/katex": "^0.16.8",
        "@types/node": "^24.12.2",
        "@vitest/browser": "^4.1.5",
        "@vitest/browser-playwright": "^4.1.5",
        "@vitest/coverage-v8": "^4.1.5",
        "eslint-plugin-solid": "^0.14.5",
        "playwright": "^1.59.1",
        "storybook": "^10.3.5",
        "storybook-solidjs-vite": "^10.0.12",
        "typescript": "^5.9.3",
        "vite": "^7.3.2",
        "vite-plugin-solid": "^2.11.12",
        "vitest": "^4.1.5"
    }
}
