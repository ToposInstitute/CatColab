{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "lib": ["ES2023"],
        "skipLibCheck": true,

        "moduleResolution": "bundler",
        "isolatedModules": true,

        "declaration": true,
        "outDir": "dist",
        "rootDir": "src",

        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": ["src"]
}
