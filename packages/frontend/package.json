{
    "name": "frontend",
    "version": "0.1.0",
    "private": true,
    "license": "MIT",
    "type": "module",
    "scripts": {
        "build:wasm": "pnpm --prefix ../catlog-wasm run build:browser",
        "build:bindings": "cargo run -p backend -- generate-bindings",
        "build:tcm": "tcm -p 'src/**/*.module.css' .",
        "build:deps": "pnpm run build:wasm && pnpm run build:bindings && pnpm run build:tcm",
        "build": "tsc -b && vite build --sourcemap true",
        "build:staging": "tsc -b && vite build --sourcemap true --mode staging",
        "preview": "vite preview",
        "format": "oxfmt .",
        "check": "pnpm run build:deps && pnpm run lint && tsc",
        "lint": "oxlint --fix && oxfmt . && stylelint 'src/**/*.css' --fix",
        "ci": "oxlint --deny-warnings && oxfmt --check . && stylelint 'src/**/*.css'",
        "doc": "typedoc --entryPointStrategy expand ./src",
        "test": "vitest --mode=development",
        "test:ci": "vitest --mode=development --cache=false --configLoader=runner --run",
        "dev": "pnpm run build:deps && vite --host",
        "staging": "pnpm run build:deps && vite --mode staging"
    },
    "dependencies": {
        "@atlaskit/pragmatic-drag-and-drop": "^1.3.0",
        "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.0.3",
        "@automerge/automerge": "^3.2.4",
        "@automerge/automerge-repo": "^2.5.3",
        "@automerge/automerge-repo-network-websocket": "^2.5.3",
        "@automerge/automerge-repo-storage-indexeddb": "^2.5.3",
        "@automerge/prosemirror": "^v0.2.0",
        "@benrbray/prosemirror-math": "^1.0.0",
        "@corvu/dialog": "^0.2.4",
        "@corvu/popover": "^0.2.0",
        "@corvu/resizable": "^0.2.5",
        "@corvu/tooltip": "^0.2.2",
        "@mdx-js/rollup": "^3.1.0",
        "@modular-forms/solid": "^0.24.1",
        "@qubit-rs/client": "^0.4.5",
        "@solid-primitives/context": "^0.3.1",
        "@solid-primitives/destructure": "^0.2.1",
        "@solid-primitives/event-listener": "^2.4.3",
        "@solid-primitives/map": "^0.7.2",
        "@solid-primitives/timer": "^1.4.1",
        "@solidjs/meta": "^0.29.4",
        "@solidjs/router": "^0.15.3",
        "@viz-js/viz": "^3.15.0",
        "catcolab-api": "link:../backend/pkg",
        "catcolab-ui-components": "link:../ui-components",
        "catlog-wasm": "link:../catlog-wasm/dist/pkg-browser",
        "echarts": "^5.5.1",
        "echarts-solid": "^0.2.0",
        "elkjs": "^0.11.0",
        "fast-equals": "^5.2.2",
        "fast-json-patch": "^3.1.1",
        "firebase": "^10.14.0",
        "html-escaper": "^3.0.3",
        "js-file-download": "^0.4.12",
        "katex": "^0.16.22",
        "lucide-solid": "^0.471.0",
        "prosemirror-commands": "^1.7.1",
        "prosemirror-inputrules": "^1.5.0",
        "prosemirror-keymap": "^1.2.3",
        "prosemirror-model": "^1.25.2",
        "prosemirror-schema-list": "^1.5.1",
        "prosemirror-state": "^1.4.3",
        "prosemirror-transform": "^1.10.4",
        "prosemirror-view": "^1.40.1",
        "solid-firebase": "^0.3.0",
        "solid-js": "^1.9.10",
        "tiny-invariant": "^1.3.3",
        "ts-pattern": "^5.2.0",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@mdx-js/mdx": "^2.3.0",
        "@types/html-escaper": "^3.0.4",
        "@types/mdx": "^2.0.13",
        "@types/node": "^24.0.0",
        "eslint-plugin-solid": "^0.14.5",
        "rehype-katex": "^7.0.1",
        "rehype-raw": "^7.0.0",
        "remark-math": "^6.0.0",
        "solid-mdx": "^0.0.7",
        "typed-css-modules": "^0.9.1",
        "typedoc": "^0.26.8",
        "typescript": "^5.2.2",
        "vite": "^7.2.2",
        "vite-plugin-solid": "^2.11.10",
        "vite-plugin-wasm": "^3.5.0",
        "vitest": "^4.0.8",
        "wasm-pack": "^0.14.0",
        "web-worker": "^1.5.0"
    }
}
