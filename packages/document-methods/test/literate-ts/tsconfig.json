{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "ignoreDeprecations": "6.0",
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "lib": ["ES2023", "DOM"],
        "paths": {
            "catcolab-logics": ["./catcolab-logics.ts"],
            "catcolab-document-methods/future": ["../../src/future/index.ts"],
            "catcolab-document-methods/future/backends/solid": [
                "../../src/future/backends/solid.ts"
            ],
            "catcolab-document-methods/future/backends/automerge": [
                "../../src/future/backends/automerge.ts"
            ]
        },
        "noUnusedLocals": false,
        "noEmit": false
    }
}
