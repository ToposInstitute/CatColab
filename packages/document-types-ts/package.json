{
    "name": "document-types",
    "version": "0.1.0",
    "private": true,
    "license": "MIT",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build:node": "wasm-pack build ../document-types-rs --target nodejs -d ../document-types-ts/dist/pkg-node",
