{
    "name": "frontend-gaios",
    "version": "0.0.1",
    "description": "version of catcolab that can run in GAIOS",
    "keywords": [],
    "author": "Ink & Switch",
    "type": "module",
    "main": "src/index.ts",
    "exports": {
        ".": "./dist/index.js"
    },
    "scripts": {
        "build-deps": "pnpm --prefix ../frontend run build:deps",
        "build": "vite build",
        "push": "pnpm build && pushwork sync",
        "format": "oxfmt .",
        "lint": "oxlint --fix && oxfmt . && stylelint --allow-empty-input 'src/**/*.css' --fix",
        "check": "pnpm run lint && tsc",
        "ci": "tsc --noEmit && oxlint --deny-warnings && oxfmt --check . && stylelint --allow-empty-input 'src/**/*.css'",
        "watch": "nodemon --watch src -e js,tsx,ts,tsx,css,json --exec 'pnpm build && pnpm push'"
    },
    "dependencies": {
        "@automerge/automerge": "^3.2.5",
        "@automerge/automerge-repo": "^2.5.5",
        "@automerge/automerge-repo-react-hooks": "^2.5.5",
        "@patchwork/context": "github:inkandswitch/context",
        "catlog-wasm": "link:../catlog-wasm/dist/pkg-browser",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "solid-js": "^1.9.7",
        "uuid": "^11.0.3"
    },
    "devDependencies": {
        "@types/react": "^18.3.3",
        "@types/uuid": "^10.0.0",
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.4.20",
        "eslint-plugin-solid": "^0.14.5",
        "nodemon": "^3.1.9",
        "pushwork": "^1.1.8",
        "typescript": "^5.2.2",
        "vite": "^5.3.4",
        "vite-plugin-css-injected-by-js": "^3.5.2",
        "vite-plugin-solid": "^2.10.2",
        "vite-plugin-wasm": "^3.3.0"
    }
}
