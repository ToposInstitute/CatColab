\title{Promonads}
\taxon{theory}
\import{macros}

\p{A \define{theory of promonads} is the simple double theory generated by

\ul{
  \li{an object #{x}}
  \li{a proarrow #{p: x \proto x}}
  \li{a globular cell #{\theta: \id_x \To p}, the \define{unit}}
}

subject to the equations

\ul{
  \li{\em{Composition}: #{p \odot p = p}}
  \li{\em{Unitality}: #{1_p \odot \theta = 1_p = \theta \odot 1_p}.}
}
}

\p{In other words, the unitality axioms are:

\centerfigs{
\quiverinline{
% https://q.uiver.app/#
\begin{tikzcd}
	x & x & x \\
	x & x & x
	\arrow[""{name=0, anchor=center, inner sep=0}, "p"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow[equals, from=1-1, to=2-1]
	\arrow[""{name=1, anchor=center, inner sep=0}, "{\mathrm{id}_x}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-2, to=1-3]
	\arrow[equals, from=1-2, to=2-2]
	\arrow[equals, from=1-3, to=2-3]
	\arrow[""{name=2, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-2]
	\arrow[""{name=3, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-2, to=2-3]
	\arrow["{1_p}"{description}, draw=none, from=0, to=2]
	\arrow["\theta"{description}, draw=none, from=1, to=3]
\end{tikzcd}
}
#{\;=\;}
\quiverinline{
% https://q.uiver.app/#
\begin{tikzcd}
	x & x \\
	x & x
	\arrow[""{name=0, anchor=center, inner sep=0}, "p"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow[equals, from=1-1, to=2-1]
	\arrow[equals, from=1-2, to=2-2]
	\arrow[""{name=1, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-2]
	\arrow["{1_p}"{description}, draw=none, from=0, to=1]
\end{tikzcd}
}
#{\;=\;}
\quiverinline{
% https://q.uiver.app/#
\begin{tikzcd}
	x & x & x \\
	x & x & x
	\arrow[""{name=0, anchor=center, inner sep=0}, "{\mathrm{id}_x}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow[equals, from=1-1, to=2-1]
	\arrow[""{name=1, anchor=center, inner sep=0}, "p"{inner sep=.8ex}, "\shortmid"{marking}, from=1-2, to=1-3]
	\arrow[equals, from=1-2, to=2-2]
	\arrow[equals, from=1-3, to=2-3]
	\arrow[""{name=2, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-2]
	\arrow[""{name=3, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-2, to=2-3]
	\arrow["\theta"{description}, draw=none, from=0, to=2]
	\arrow["{1_p}"{description}, draw=none, from=1, to=3]
\end{tikzcd}
}
}

}

\p{The axioms imply the \em{functorality} equation #{\theta \odot \theta =
\theta} via two possible calculations, for example:

\centerfigs{
\quiverinline{
% https://q.uiver.app/#
\begin{tikzcd}
	x & x & x \\
	x & x & x
	\arrow[""{name=0, anchor=center, inner sep=0}, "{\mathrm{id}_x}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow[equals, from=1-1, to=2-1]
	\arrow[""{name=1, anchor=center, inner sep=0}, "{\mathrm{id}_x}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-2, to=1-3]
	\arrow[equals, from=1-2, to=2-2]
	\arrow[equals, from=1-3, to=2-3]
	\arrow[""{name=2, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-2]
	\arrow[""{name=3, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-2, to=2-3]
	\arrow["\theta"{description}, draw=none, from=0, to=2]
	\arrow["\theta"{description}, draw=none, from=1, to=3]
\end{tikzcd}
}
#{\;=\;}
\quiverinline{
% https://q.uiver.app/#
\begin{tikzcd}[column sep=large]
	x & x & x \\
	x & x & x \\
	x & x & x
	\arrow[""{name=0, anchor=center, inner sep=0}, "{\mathrm{id}_x}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow[equals, from=1-1, to=2-1]
	\arrow[""{name=1, anchor=center, inner sep=0}, "{\mathrm{id}_x}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-2, to=1-3]
	\arrow[equals, from=1-2, to=2-2]
	\arrow[equals, from=1-3, to=2-3]
	\arrow[""{name=2, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-2]
	\arrow[equals, from=2-1, to=3-1]
	\arrow[""{name=3, anchor=center, inner sep=0}, "{\mathrm{id}_x}"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-2, to=2-3]
	\arrow[equals, from=2-2, to=3-2]
	\arrow[equals, from=2-3, to=3-3]
	\arrow[""{name=4, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=3-1, to=3-2]
	\arrow[""{name=5, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=3-2, to=3-3]
	\arrow["\theta"{description}, draw=none, from=0, to=2]
	\arrow["{1_{\mathrm{id}_x} = \mathrm{id}_{1_x}}"{description}, draw=none, from=1, to=3]
	\arrow["{1_p}"{description, pos=0.6}, draw=none, from=2, to=4]
	\arrow["\theta"{description, pos=0.6}, draw=none, from=3, to=5]
\end{tikzcd}
}
#{\;=\;}
\quiverinline{
% https://q.uiver.app/#
\begin{tikzcd}
	x & x \\
	x & x
	\arrow[""{name=0, anchor=center, inner sep=0}, "{\mathrm{id}_x}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow[equals, from=1-1, to=2-1]
	\arrow[equals, from=1-2, to=2-2]
	\arrow[""{name=1, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-2]
	\arrow["\theta"{description}, draw=none, from=0, to=1]
\end{tikzcd}
}
}

}
