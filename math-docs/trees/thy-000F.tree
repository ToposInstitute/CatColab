\title{Generalized multicategories}
\taxon{theory}
\import{macros}

\p{The \define{theory of generalized multicategories} is the modal virtual
double theory #{(\dbl{T}, T)} generated by

\ul{
  \li{an object #{x}}
  \li{a proarrow #{p: Tx \proto x}}
}

having the composites:

\ul{
  \li{\em{Composition}: The composite #{Tp \odot p} exists and is the
  restriction #{p(\mu_x,1_x) = (\mu_x)_! \odot p}.}
  \li{\em{Normalization}: The unit #{\id_x} is the restriction
  #{p(\eta_x,1_x) = (\eta_x)_! \odot p}.}
  \li{\em{Associativity}: The composite #{T^2 p \odot (\mu_x)_!} exists and is
  the restriction #{(Tp)(\mu_{Tx},1_{Tx}) = (\mu_{Tx})_! \odot Tp}.}
}

and satisfying the cell equations:

\ul{

  \li{\em{Compatibility of left action}:
  \centerfigs{
  \quiverinline{
  % https://q.uiver.app/#
  \begin{tikzcd}
	Tx & Tx & x \\
	{T^2 x} & Tx & x \\
	{T^2 x} && x \\
	Tx && x
	\arrow[""{name=0, anchor=center, inner sep=0}, "{\id_{Tx}}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow["{T\eta_x}"', from=1-1, to=2-1]
	\arrow[""{name=1, anchor=center, inner sep=0}, "p"{inner sep=.8ex}, "\shortmid"{marking}, from=1-2, to=1-3]
	\arrow[equals, from=1-2, to=2-2]
	\arrow[from=1-3, to=2-3]
	\arrow[""{name=2, anchor=center, inner sep=0}, "Tp"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-2]
	\arrow[equals, from=2-1, to=3-1]
	\arrow[""{name=3, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-2, to=2-3]
	\arrow[equals, from=2-3, to=3-3]
	\arrow[""{name=4, anchor=center, inner sep=0}, "{(\mu_x)_! \odot p}"'{inner sep=.8ex}, "\shortmid"{marking}, from=3-1, to=3-3]
	\arrow["{\mu_x}"', from=3-1, to=4-1]
	\arrow[equals, from=3-3, to=4-3]
	\arrow[""{name=5, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=4-1, to=4-3]
	\arrow["{T(\text{res})}"{description}, draw=none, from=0, to=2]
	\arrow["{1_p}"{description}, draw=none, from=1, to=3]
	\arrow["{\text{comp}}"{description, pos=0.4}, draw=none, from=2-2, to=4]
	\arrow["{\text{res}}"{description, pos=0.6}, draw=none, from=4, to=5]
  \end{tikzcd}
  }
  #{\qquad=\qquad}
  \quiverinline{
  % https://q.uiver.app/#
  \begin{tikzcd}
	Tx & Tx & x \\
	Tx && x
	\arrow["{\id_{Tx}}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow[equals, from=1-1, to=2-1]
	\arrow["p"{inner sep=.8ex}, "\shortmid"{marking}, from=1-2, to=1-3]
	\arrow[equals, from=1-3, to=2-3]
	\arrow[""{name=0, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-3]
	\arrow["{\text{comp}}"{description, pos=0.4}, draw=none, from=1-2, to=0]
  \end{tikzcd}
  }
  }
  }

  \li{\em{Compatibility of right action}:
  \centerfigs{
  \quiverinline{
  % https://q.uiver.app/#
  \begin{tikzcd}
	Tx & x & x \\
	{T^2 x} & Tx & x \\
	{T^2 x} && x \\
	Tx && x
	\arrow[""{name=0, anchor=center, inner sep=0}, "p"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow["{\eta_{Tx}}"', from=1-1, to=2-1]
	\arrow[""{name=1, anchor=center, inner sep=0}, "{\id_x}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-2, to=1-3]
	\arrow["{\eta_x}"{description}, from=1-2, to=2-2]
	\arrow[equals, from=1-3, to=2-3]
	\arrow[""{name=2, anchor=center, inner sep=0}, "Tp"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-2]
	\arrow[equals, from=2-1, to=3-1]
	\arrow[""{name=3, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-2, to=2-3]
	\arrow[equals, from=2-3, to=3-3]
	\arrow[""{name=4, anchor=center, inner sep=0}, "{(\mu_x)_! \odot p}"'{inner sep=.8ex}, "\shortmid"{marking}, from=3-1, to=3-3]
	\arrow["{\mu_x}"', from=3-1, to=4-1]
	\arrow[equals, from=3-3, to=4-3]
	\arrow[""{name=5, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=4-1, to=4-3]
	\arrow["{\eta_p}"{description}, draw=none, from=0, to=2]
	\arrow["{\text{res}}"{description}, draw=none, from=1, to=3]
	\arrow["{\text{comp}}"{description, pos=0.4}, draw=none, from=2-2, to=4]
	\arrow["{\text{res}}"{description, pos=0.6}, draw=none, from=4, to=5]
  \end{tikzcd}
  }
  #{\qquad=\qquad}
  \quiverinline{
  % https://q.uiver.app/#
  \begin{tikzcd}
	Tx & x & x \\
	Tx && x
	\arrow["p"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow[equals, from=1-1, to=2-1]
	\arrow["{\id_x}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-2, to=1-3]
	\arrow[equals, from=1-3, to=2-3]
	\arrow[""{name=0, anchor=center, inner sep=0}, "p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-3]
	\arrow["{\text{comp}}"{description, pos=0.4}, draw=none, from=1-2, to=0]
  \end{tikzcd}
  }
  }
  }

  \li{\em{Associativity}:
  \centerfigs{
  \quiverinline{
  % https://q.uiver.app/#
  \begin{tikzcd}
	{T^3 x} & {T^2 x} & Tx \\
	{T^2 x} & Tx & Tx \\
	{T^2 x} && Tx
	\arrow[""{name=0, anchor=center, inner sep=0}, "{T^2 p}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow["{\mu_{Tx}}"', from=1-1, to=2-1]
	\arrow[""{name=1, anchor=center, inner sep=0}, "{(\mu_x)_!}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-2, to=1-3]
	\arrow["{\mu_x}"{description}, from=1-2, to=2-2]
	\arrow[equals, from=1-3, to=2-3]
	\arrow[""{name=2, anchor=center, inner sep=0}, "Tp"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-2]
	\arrow[equals, from=2-1, to=3-1]
	\arrow[""{name=3, anchor=center, inner sep=0}, "{\id_{Tx}}"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-2, to=2-3]
	\arrow[equals, from=2-3, to=3-3]
	\arrow[""{name=4, anchor=center, inner sep=0}, "Tp"'{inner sep=.8ex}, "\shortmid"{marking}, from=3-1, to=3-3]
	\arrow["{\mu_p}"{description}, draw=none, from=0, to=2]
	\arrow["{\text{res}}"{description}, draw=none, from=1, to=3]
	\arrow["{\text{comp}}"{description, pos=0.4}, draw=none, from=2-2, to=4]
  \end{tikzcd}
  }
  #{\qquad=\qquad}
  \quiverinline{
  % https://q.uiver.app/#
  \begin{tikzcd}
	{T^3 x} & {T^2 x} & Tx \\
	{T^3 x} && Tx \\
	{T^2 x} && Tx
	\arrow["{T^2 p}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow[equals, from=1-1, to=2-1]
	\arrow["{(\mu_x)_!}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-2, to=1-3]
	\arrow[equals, from=1-3, to=2-3]
	\arrow[""{name=0, anchor=center, inner sep=0}, "{(\mu_{Tx})_! \odot Tp}"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-3]
	\arrow["{\mu_{Tx}}"', from=2-1, to=3-1]
	\arrow[equals, from=2-3, to=3-3]
	\arrow[""{name=1, anchor=center, inner sep=0}, "Tp"'{inner sep=.8ex}, "\shortmid"{marking}, from=3-1, to=3-3]
	\arrow["{\text{comp}}"{description, pos=0.4}, draw=none, from=1-2, to=0]
	\arrow["{\text{res}}"{description, pos=0.6}, draw=none, from=0, to=1]
  \end{tikzcd}
  }
  }
  }

}
}

\subtree{
  \title{Interpretation of the axioms}
  \taxon{remark}

  \p{The axioms of this theory might seem opaque at first glance, but the three
  axioms on composites are intuitively just transposes of familiar laws. The
  first two are transposes of the monad algebra laws, which we might write
  informally as commutative diagrams:

  \quiver{
  % https://q.uiver.app/#
  \begin{tikzcd}
	{T^2 x} & Tx && x & Tx \\
	Tx & x &&& x
	\arrow["Tp"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow["{(\mu_x)_!}"'{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=2-1]
	\arrow["p"{inner sep=.8ex}, "\shortmid"{marking}, from=1-2, to=2-2]
	\arrow["{(\eta_x)_!}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-4, to=1-5]
	\arrow["{\mathrm{id}_x}"'{inner sep=.8ex}, "\shortmid"{marking}, from=1-4, to=2-5]
	\arrow["p"{inner sep=.8ex}, "\shortmid"{marking}, from=1-5, to=2-5]
	\arrow["p"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-2]
  \end{tikzcd}
  }

  Similarly, the third axiom on composites can be informally pictured as the
  naturality square for the transposed monad multiplication at #{p}:

  \quiver{
  % https://q.uiver.app/#
  \begin{tikzcd}
	{T^3 x} & {T^2 x} \\
	{T^2 x} & Tx
	\arrow["{T^2 p}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=1-2]
	\arrow["{(\mu_{Tx})_!}"'{inner sep=.8ex}, "\shortmid"{marking}, from=1-1, to=2-1]
	\arrow["{(\mu_x)_!}"{inner sep=.8ex}, "\shortmid"{marking}, from=1-2, to=2-2]
	\arrow["Tp"'{inner sep=.8ex}, "\shortmid"{marking}, from=2-1, to=2-2]
  \end{tikzcd}
  }

  The three equational axioms then ensure that any "extra" composition cells are
  uniquely determined by the multicategory's composition operation.}

  \p{The two axioms labeled "associativity" are somewhat mysterious. As the name
  suggests, they are used in proving that the multicategory has associative
  composition. Taken together, they can be read as saying that the cell
  component #{\mu_p} of the monad multiplication, when transformed by sliding
  arrows into proarrows via companions (cf. [Patterson
  2026](patterson-transposing-2026), Equation 2.1), is a composition
  (opcartesian) cell. Note that so constraining the monad on the theory does
  \em{not} constrain the monad on the semantics; it only determines the image of
  a composition cell in models of the theory. \em{Open question}: Should such
  laws belong to the definition of a modal virtual double theory?}

}
